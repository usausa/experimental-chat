<div class="message-input-container">
    <div class="message-input-wrapper">
        <div class="input-toolbar">
            <button class="toolbar-btn" title="Bold (*text*)" @onclick='() => InsertFormatAsync("*", "*")'>𝐁</button>
            <button class="toolbar-btn" title="Italic (_text_)" @onclick='() => InsertFormatAsync("_", "_")'>𝐼</button>
            <button class="toolbar-btn" title="Strikethrough (~text~)" @onclick='() => InsertFormatAsync("~", "~")'>S̶</button>
            <span class="toolbar-divider"></span>
            <button class="toolbar-btn" title="Code" @onclick='() => InsertFormatAsync("`", "`")'>&lt;/&gt;</button>
            <button class="toolbar-btn" title="Quote (> text)" @onclick='() => InsertFormatAsync("> ", "")'>❝</button>
        </div>
        <div class="input-area">
            <textarea @ref="inputRef"
                      @bind="MessageText"
                      @bind:event="oninput"
                      @onkeydown="HandleKeyDownAsync"
                      placeholder="@Placeholder"
                      rows="1"></textarea>
        </div>
        <div class="input-footer">
            <div class="input-actions-left">
                <button class="footer-btn" title="Attach file" @onclick="ToggleAttachDialog">📎</button>
                <div class="footer-btn-wrapper">
                    <button class="footer-btn" title="Emoji" @onclick="ToggleEmojiPicker" @onclick:stopPropagation="true">😊</button>
                    @if (showEmojiPicker)
                    {
                        <div class="emoji-picker-anchor">
                            <EmojiPicker OnSelect="InsertEmojiAsync" OnClose="CloseEmojiPicker" />
                        </div>
                    }
                </div>
                <button class="footer-btn" title="Mention" @onclick="InsertMentionAsync">＠</button>
            </div>
            <div class="input-actions-right">
                <button class="send-btn @(string.IsNullOrWhiteSpace(MessageText) ? "send-btn-disabled" : "")"
                        @onclick="SendAsync"
                        disabled="@string.IsNullOrWhiteSpace(MessageText)"
                        title="Send message">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M1.5 1.5L14.5 8L1.5 14.5V9.5L10.5 8L1.5 6.5V1.5Z" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

    @if (showAttachDialog)
    {
        <div class="mini-dialog-backdrop" @onclick="() => showAttachDialog = false"></div>
        <div class="mini-dialog">
            <div class="mini-dialog-header">
                <span>Upload a file</span>
                <button class="mini-dialog-close" @onclick="() => showAttachDialog = false">✕</button>
            </div>
            <div class="mini-dialog-body">
                <div class="attach-dropzone">
                    <span class="attach-dropzone-icon">📁</span>
                    <p>Drag and drop a file here, or click to browse</p>
                    <button class="attach-browse-btn">Browse files</button>
                </div>
            </div>
        </div>
    }
</div>
